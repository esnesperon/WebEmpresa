---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/ui';
import { getSeo } from '../i18n/seo';
import { faqData } from '../i18n/faq-data';

const t = useTranslations('es');
const seo = getSeo('es', 'faq');
const sections = faqData['es'];
const allItems = sections.flatMap(s => s.items);
const catLabels: Record<string, string> = {
    general: t('faq.cat.general'),
    servicios: t('faq.cat.services'),
    proceso: t('faq.cat.process'),
    datos: t('faq.cat.data'),
};
---
<BaseLayout
    title={seo.title}
    description={seo.description}
    locale="es-ES"
    serviceArea={seo.serviceArea}
    tags={seo.keywords}
    faq={allItems.map(item => ({ question: item.q, answer: item.a }))}
    alternateLocales={[
        { locale: 'en-US', url: 'https://orviq.net/en/faq' },
        { locale: 'fr-FR', url: 'https://orviq.net/fr/faq' }
    ]}
>
    <div class="fixed inset-0 z-[-2] w-full h-full object-cover opacity-20 mix-blend-luminosity bg-[url('https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2564&auto=format&fit=crop')] bg-cover bg-center" data-alt="Abstract slow moving dark liquid glass cinematic background"></div>
    <div class="fixed top-0 left-0 w-full h-[300px] bg-gradient-to-b from-background to-transparent z-[-1] pointer-events-none"></div>
    <div class="fixed bottom-0 left-0 w-full h-[300px] bg-gradient-to-t from-background to-transparent z-[-1] pointer-events-none"></div>

    <main class="max-w-[1440px] mx-auto px-6 md:px-16 pt-48 pb-32">
        <header class="mb-24 max-w-3xl">
            <h1 class="font-[Fraunces] text-5xl md:text-7xl lg:text-[80px] leading-[1.1] tracking-[-0.02em] font-semibold text-on-background mb-6">{t('faq.title')}</h1>
            <p class="text-[18px] leading-[1.6] text-on-surface-variant">{t('faq.desc')}</p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
            <aside class="md:col-span-3 md:sticky md:top-32 h-fit">
                <nav class="flex flex-col gap-2">
                    {sections.map((section, i) => (
                        <button class:list={[
                            'faq-nav-btn text-left text-xs uppercase tracking-widest font-semibold border-l-2 pl-4 py-1',
                            i === 0
                                ? 'text-primary border-primary'
                                : 'text-on-surface-variant hover:text-on-background border-transparent transition-colors'
                        ]} data-target={`faq-${section.id}`}>
                            {catLabels[section.id]}
                        </button>
                    ))}
                </nav>
            </aside>

            <div class="md:col-span-9 space-y-6">
                {sections.map((section, si) => (
                    <section id={`faq-${section.id}`} class:list={[si > 0 && 'mt-16']}>
                        <h2 class="font-[Fraunces] text-2xl md:text-[32px] leading-[1.3] font-semibold text-on-background mb-8 pb-4 border-b border-surface-variant">{catLabels[section.id]}</h2>
                        <div class="space-y-4">
                            {section.items.map((item, ii) => (
                                <div class="faq-item bg-surface-container/30 backdrop-blur-[20px] border border-white/5 rounded-xl overflow-hidden cursor-pointer hover:bg-surface-container/50 transition-colors">
                                    <button class="faq-header w-full text-left p-6 flex justify-between items-center focus:outline-none focus:bg-surface-container-high/50" aria-expanded="false" aria-controls={`faq-content-${si}-${ii}`}>
                                        <h3 class="text-xl font-semibold text-on-background pr-4">{item.q}</h3>
                                        <span class="faq-icon material-symbols-outlined text-on-surface-variant transition-transform duration-300 flex-shrink-0">expand_more</span>
                                    </button>
                                    <div id={`faq-content-${si}-${ii}`} class="faq-content px-6 overflow-hidden transition-all duration-500 ease-in-out" style="max-height: 0; opacity: 0;">
                                        <div class="border-t border-white/5 pt-4 pb-6">
                                            <p class="text-base leading-[1.6] text-on-surface-variant">{item.a}</p>
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </section>
                ))}
            </div>
        </div>

        <div class="mt-32 p-8 md:p-12 bg-primary-container/20 backdrop-blur-[40px] border border-primary/20 rounded-2xl text-center max-w-4xl mx-auto relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent pointer-events-none"></div>
            <h2 class="font-[Fraunces] text-3xl md:text-[48px] leading-[1.2] font-semibold text-on-background mb-4 relative z-10">{t('faq.more.title')}</h2>
            <p class="text-base md:text-[18px] leading-[1.6] text-on-surface-variant mb-8 relative z-10 max-w-2xl mx-auto">{t('faq.more.desc')}</p>

            <a href="/contact" class="relative z-10 bg-primary text-on-primary px-8 py-4 rounded-full text-xs uppercase tracking-widest font-semibold hover:bg-primary-fixed-dim transition-colors inline-block">{t('faq.more.cta')}</a>
        </div>
    </main>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', function() {
            const faqItems = document.querySelectorAll('.faq-item');
            faqItems.forEach(item => {
                const header = item.querySelector('.faq-header');
                const content = item.querySelector('.faq-content');
                const icon = item.querySelector('.faq-icon');
                header.addEventListener('click', () => {
                    const isOpen = content.style.maxHeight !== '0px' && content.style.maxHeight !== '';
                    faqItems.forEach(otherItem => {
                        const otherContent = otherItem.querySelector('.faq-content');
                        const otherIcon = otherItem.querySelector('.faq-icon');
                        const otherHeader = otherItem.querySelector('.faq-header');
                        otherContent.style.maxHeight = '0px';
                        otherContent.style.opacity = '0';
                        otherIcon.style.transform = 'rotate(0deg)';
                        if (otherHeader) otherHeader.setAttribute('aria-expanded', 'false');
                    });
                    if (!isOpen) {
                        content.style.maxHeight = content.scrollHeight + 'px';
                        content.style.opacity = '1';
                        icon.style.transform = 'rotate(180deg)';
                        header.setAttribute('aria-expanded', 'true');
                    }
                });
            });

            const sections = document.querySelectorAll('section[id^="faq-"]');
            const navBtns = document.querySelectorAll('.faq-nav-btn');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        navBtns.forEach(btn => {
                            const isActive = btn.dataset.target === entry.target.id;
                            btn.classList.toggle('text-primary', isActive);
                            btn.classList.toggle('border-primary', isActive);
                            btn.classList.toggle('text-on-surface-variant', !isActive);
                            btn.classList.toggle('border-transparent', !isActive);
                        });
                    }
                });
            }, { threshold: 0.3 });
            sections.forEach(s => observer.observe(s));

            navBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    const target = document.getElementById(btn.dataset.target);
                    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                });
            });
        });
    </script>
</BaseLayout>
