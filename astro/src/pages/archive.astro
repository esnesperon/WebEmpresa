---
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects')).filter(p => p.id.startsWith('es/'));

function getProjectSlug(id) {
    return id.replace('es/', '').replace('.md', '');
}
---

<BaseLayout title="Archive | Orviq" description="Complete index of experiments and shipped digital couture.">
    <header class="relative pt-48 md:pt-64 pb-16 px-6 md:px-12 max-w-[1440px] mx-auto w-full">
        <div class="max-w-4xl">
            <h1 class="font-[Fraunces] text-5xl md:text-7xl lg:text-[80px] text-on-background mb-8">Archive</h1>
            <p class="text-lg text-on-surface-variant max-w-2xl">Complete index of experiments, prototypes, and shipped digital couture.</p>
        </div>
    </header>

    <main class="flex-grow px-6 md:px-12 max-w-[1440px] mx-auto w-full pb-32 md:pb-64">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {allProjects.map(project => (
                <a href={`/work/${getProjectSlug(project.id)}`} class="group liquid-glass rounded-xl overflow-hidden cursor-pointer hover:shadow-[0_0_30px_rgba(196,192,255,0.15)] transition-all duration-500">
                    <div class="relative h-64 overflow-hidden">
                        <OptimizedImage src={project.data.image} alt={project.data.title} loading="lazy" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105 opacity-80 group-hover:opacity-100" sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw" />
                    </div>
                    <div class="p-8">
                        <span class="px-3 py-1 bg-primary/10 text-primary text-xs uppercase tracking-wider rounded">{project.data.category}</span>
                        <h2 class="font-[Fraunces] text-3xl text-on-background mt-4 mb-2 group-hover:text-primary transition-colors">{project.data.title}</h2>
                        <p class="text-base text-on-surface-variant">{project.data.description}</p>
                    </div>
                </a>
            ))}
        </div>
    </main>
</BaseLayout>
