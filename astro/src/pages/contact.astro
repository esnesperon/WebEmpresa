---
import BaseLayout from '../layouts/BaseLayout.astro';
import contactData from '../data/contact.json';
import { useTranslations } from '../i18n/ui';
import { getSeo } from '../i18n/seo';

const t = useTranslations('es');
const seo = getSeo('es', 'contact');

const contactWebhook = import.meta.env.PUBLIC_N8N_CONTACT_WEBHOOK || '';
const turnstileKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';

const sendingText = t('contact.sending');
const submitText = t('contact.submit');
const successText = t('contact.success');
const errorText = t('contact.error');
---

<BaseLayout
    title={seo.title}
    description={seo.description}
    locale="es-ES"
    serviceArea={seo.serviceArea}
    tags={seo.keywords}
    alternateLocales={[
        { locale: 'en-US', url: 'https://orviq.net/en/contact' },
        { locale: 'fr-FR', url: 'https://orviq.net/fr/contact' }
    ]}
>
    <div class="fixed inset-0 z-[-2] w-full h-full object-cover opacity-20 mix-blend-luminosity bg-[url('https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?q=80&w=2564&auto=format&fit=crop')] bg-cover bg-center"></div>
    <div class="fixed top-0 left-0 w-full h-[300px] bg-gradient-to-b from-background to-transparent z-[-1] pointer-events-none"></div>
    <div class="fixed bottom-0 left-0 w-full h-[300px] bg-gradient-to-t from-background to-transparent z-[-1] pointer-events-none"></div>

    <main class="flex-grow pt-40 pb-24 px-6 md:px-16 max-w-[1440px] w-full mx-auto z-10">
        <header class="mb-16 max-w-3xl">
            <span class="text-xs text-primary uppercase tracking-[0.2em] mb-4 block font-semibold">{t('contact.initiate')}</span>
            <h1 class="font-[Fraunces] text-5xl md:text-7xl lg:text-[80px] leading-[1.1] tracking-[-0.02em] font-semibold text-on-surface">{t('contact.title')}</h1>
        </header>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
            <div class="lg:col-span-7">
                <div class="bg-surface-container-high/30 backdrop-blur-[40px] border border-outline-variant/20 rounded-xl p-8 md:p-12 shadow-[0_0_40px_rgba(196,192,255,0.03)] relative overflow-hidden h-full">
                    <div class="absolute inset-0 bg-[linear-gradient(135deg,rgba(255,255,255,0.05)_0%,transparent_100%)] pointer-events-none"></div>
                    <form id="contact-form" class="flex flex-col gap-10 relative z-10" data-webhook={contactWebhook}>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10">
                            <div class="flex flex-col group">
                                <label for="contact-name" class="text-xs text-on-surface-variant mb-3 uppercase tracking-widest font-semibold transition-colors group-focus-within:text-primary">{t('contact.field.name')} <span class="text-primary">*</span></label>
                                <input id="contact-name" name="name" required autocomplete="name" class="bg-transparent border-0 border-b border-outline-variant py-3 px-0 text-[18px] text-on-surface focus:ring-0 focus:border-primary transition-all placeholder:text-surface-variant" placeholder={t('contact.field.name.placeholder')} type="text" />
                            </div>
                            <div class="flex flex-col group">
                                <label for="contact-email" class="text-xs text-on-surface-variant mb-3 uppercase tracking-widest font-semibold transition-colors group-focus-within:text-primary">Email <span class="text-primary">*</span></label>
                                <input id="contact-email" name="email" required autocomplete="email" class="bg-transparent border-0 border-b border-outline-variant py-3 px-0 text-[18px] text-on-surface focus:ring-0 focus:border-primary transition-all placeholder:text-surface-variant" placeholder={t('contact.field.email.placeholder')} type="email" />
                            </div>
                        </div>
                        <div class="flex flex-col group">
                            <label for="contact-business" class="text-xs text-on-surface-variant mb-3 uppercase tracking-widest font-semibold transition-colors group-focus-within:text-primary">{t('contact.field.business')}</label>
                            <input id="contact-business" name="business" autocomplete="organization" class="bg-transparent border-0 border-b border-outline-variant py-3 px-0 text-[18px] text-on-surface focus:ring-0 focus:border-primary transition-all placeholder:text-surface-variant" placeholder={t('contact.field.business.placeholder')} type="text" />
                        </div>
                        <div class="flex flex-col group relative">
                            <label for="contact-service" class="text-xs text-on-surface-variant mb-3 uppercase tracking-widest font-semibold transition-colors group-focus-within:text-primary">{t('contact.field.service')} <span class="text-primary">*</span></label>
                            <select id="contact-service" name="service" required class="bg-transparent border-0 border-b border-outline-variant py-3 px-0 text-[18px] text-on-surface focus:ring-0 focus:border-primary transition-all appearance-none cursor-pointer">
                                <option value="" disabled selected>{t('contact.field.service.select')}</option>
                                <option class="bg-surface text-on-surface" value="automatizacion">{t('contact.service.auto')}</option>
                                <option class="bg-surface text-on-surface" value="web">{t('contact.service.web')}</option>
                                <option class="bg-surface text-on-surface" value="rag">{t('contact.service.rag')}</option>
                                <option class="bg-surface text-on-surface" value="agente">{t('contact.service.agent')}</option>
                                <option class="bg-surface text-on-surface" value="ecommerce">{t('contact.service.ecom')}</option>
                                <option class="bg-surface text-on-surface" value="branding">{t('contact.service.branding')}</option>
                                <option class="bg-surface text-on-surface" value="dashboard">{t('contact.service.saas')}</option>
                                <option class="bg-surface text-on-surface" value="app">{t('contact.service.app')}</option>
                                <option class="bg-surface text-on-surface" value="scraper">{t('contact.service.scraper')}</option>
                                <option class="bg-surface text-on-surface" value="devops">{t('contact.service.devops')}</option>
                                <option class="bg-surface text-on-surface" value="consulting">{t('contact.service.consulting')}</option>
                                <option class="bg-surface text-on-surface" value="unsure">{t('contact.service.unsure')}</option>
                            </select>
                            <span class="material-symbols-outlined absolute right-0 bottom-4 pointer-events-none text-on-surface-variant">expand_more</span>
                        </div>
                        <div class="flex flex-col group">
                            <label for="contact-message" class="text-xs text-on-surface-variant mb-3 uppercase tracking-widest font-semibold transition-colors group-focus-within:text-primary">{t('contact.field.message')} <span class="text-primary">*</span></label>
                            <textarea id="contact-message" name="message" required class="bg-transparent border-0 border-b border-outline-variant py-3 px-0 text-[18px] text-on-surface focus:ring-0 focus:border-primary transition-all resize-none placeholder:text-surface-variant" placeholder={t('contact.field.message.placeholder')} rows="4"></textarea>
                        </div>

                        <div style="position:absolute;left:-9999px" aria-hidden="true">
                            <input type="text" name="website" tabindex="-1" autocomplete="off">
                        </div>

                        <div id="turnstile-container"></div>

                        <div class="flex items-start gap-3 mt-4">
                            <input type="checkbox" id="contact-privacy" name="privacy" required class="mt-1 w-4 h-4 bg-transparent border border-outline-variant rounded focus:ring-primary text-primary" />
                            <label for="contact-privacy" class="text-sm text-on-surface-variant leading-tight">
                                {t('contact.privacy.text')} <a href="/aviso-legal" class="text-primary hover:underline">{t('contact.privacy.legal')}</a> {t('contact.privacy.and')} <a href="/privacidad" class="text-primary hover:underline">{t('contact.privacy.policy')}</a>. <span class="text-primary">*</span>
                            </label>
                        </div>

                        <div class="mt-4 flex justify-start md:justify-end">
                            <button id="form-submit" class="bg-primary text-on-primary text-xs uppercase tracking-widest font-semibold px-8 py-4 rounded hover:bg-[#e3dfff] hover:shadow-[0_0_20px_rgba(196,192,255,0.3)] transition-all duration-300 w-full md:w-auto" type="submit">
                                {t('contact.submit')}
                            </button>
                        </div>

                        <div id="form-success" class="hidden text-secondary text-sm mt-4 text-right">{t('contact.success')}</div>
                    </form>
                </div>
            </div>
            <div class="lg:col-span-5 flex flex-col gap-6">
                <div class="bg-surface-container-high/20 backdrop-blur-[20px] border border-outline-variant/15 rounded-xl p-8 relative overflow-hidden flex-grow">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-primary/5 rounded-full blur-[40px] pointer-events-none"></div>
                    <h2 class="font-[Fraunces] text-2xl md:text-[32px] leading-[1.3] font-semibold text-on-surface mb-8">{t('contact.subtitle')}</h2>
                    <div class="flex flex-col gap-8 relative z-10">
                        <div class="flex items-center gap-4 flex-wrap">
                            <span class="material-symbols-outlined text-primary text-2xl">mail</span>
                            <a class="text-base md:text-[18px] leading-[1.6] text-on-surface hover:text-primary transition-colors break-all" href={`mailto:${contactData.email}`}>{contactData.email}</a>
                        </div>
                    </div>
                    <div class="mt-12 pt-8 border-t border-outline-variant/20 relative z-10">
                        <p class="text-xs text-on-surface-variant mb-6 uppercase tracking-widest font-semibold">{t('contact.presence')}</p>
                        <div class="flex flex-wrap gap-3">
                            {contactData.socials.map(social => (
                                <a
                                    class="text-xs uppercase tracking-widest text-on-surface-variant hover:text-primary transition-colors duration-300 border border-outline-variant/20 rounded-full px-4 py-2 hover:border-primary/40 hover:bg-primary/5"
                                    href={social.url}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    aria-label={social.label}
                                >{social.name}</a>
                            ))}
                        </div>
                    </div>
                </div>
                <div class="bg-surface-container-high/10 backdrop-blur-[10px] border border-outline-variant/10 rounded-xl p-8">
                    <h3 class="text-xs text-on-surface-variant uppercase tracking-widest mb-6 font-semibold">{t('contact.faq.title')}</h3>
                    <div class="flex flex-col gap-6">
                        <div class="pb-6 border-b border-outline-variant/15">
                            <p class="text-[18px] leading-[1.6] text-on-surface mb-2 font-medium">{t('contact.faq.q1')}</p>
                            <p class="text-base leading-[1.6] text-on-surface-variant">{t('contact.faq.a1')}</p>
                        </div>
                        <div class="pb-6">
                            <p class="text-[18px] leading-[1.6] text-on-surface mb-2 font-medium">{t('contact.faq.q2')}</p>
                            <p class="text-base leading-[1.6] text-on-surface-variant">{t('contact.faq.a2')}</p>
                        </div>
                    </div>
                </div>
</div>
</div>
</main>

<section class="px-6 md:px-16 max-w-[1440px] w-full mx-auto pb-24">
<div class="max-w-3xl mb-8">
<span class="text-xs text-primary uppercase tracking-[0.2em] mb-4 block font-semibold">{t('contact.schedule.label')}</span>
<h2 class="font-[Fraunces] text-3xl md:text-5xl leading-[1.1] tracking-[-0.02em] font-semibold text-on-surface">{t('contact.schedule.title')}</h2>
<p class="text-base md:text-lg text-on-surface-variant mt-4">{t('contact.schedule.subtitle')}</p>
</div>
<div class="bg-surface-container-high/30 backdrop-blur-[40px] border border-outline-variant/20 rounded-xl overflow-hidden shadow-[0_0_40px_rgba(196,192,255,0.03)]">
<iframe src="https://cal.com/alex-esperon-wbm5ot/30min?embed=true&ui.color-scheme=dark" style="width:100%;height:600px;border:none;min-height:600px;display:block;" loading="lazy" title="Agendar llamada"></iframe>
</div>
</section>

<script is:inline define:vars={{ sendingText, submitText, successText, errorText }}>
        var contactForm = document.getElementById('contact-form');
        var turnstileSiteKey = '0x4AAAAAACvGSGyNCwh7JaJQ';
        var turnstileWidgetId = null;
        if (window.turnstile) {
            turnstileWidgetId = turnstile.render('#turnstile-container', { sitekey: turnstileSiteKey });
        }
        contactForm.addEventListener('submit', async function(e) {
            e.preventDefault();
            const btn = document.getElementById('form-submit');
            btn.textContent = sendingText;
            btn.disabled = true;

            const formData = new FormData(this);
            const data = Object.fromEntries(formData.entries());
            const webhook = this.dataset.webhook || '';

            if (!webhook) { alert(errorText); btn.textContent = submitText; btn.disabled = false; return; }

            if (data.website) {
                this.reset();
                document.getElementById('form-success').classList.remove('hidden');
                btn.textContent = submitText;
                btn.disabled = false;
                return;
            }

            try {
                const response = await fetch(webhook, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        name: data.name,
                        email: data.email,
                        business: data.business,
                        service: data.service,
                        message: data.message,
                        privacy: data.privacy ? true : false,
                        turnstileToken: data['cf-turnstile-response'],
                        timestamp: new Date().toISOString(),
                        source: window.location.href,
                    })
                });

                if (response.ok) {
                    document.getElementById('form-success').classList.remove('hidden');
                    this.reset();
                    if (window.turnstile && turnstileWidgetId !== null) window.turnstile.reset(turnstileWidgetId);
                } else {
                    throw new Error('Failed to send');
                }
            } catch (err) {
                alert(errorText);
            } finally {
                btn.textContent = submitText;
                btn.disabled = false;
            }
        });
    </script>
</BaseLayout>
