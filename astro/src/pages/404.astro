---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
    title="404 | Orviq"
    description="Página no encontrada. Vuelve al inicio o explora nuestros servicios."
    type="website"
    robots="noindex, nofollow"
>
    <main class="flex-grow flex items-center justify-center min-h-[60vh]">
        <div class="text-center px-6">
            <span class="font-[Fraunces] text-[120px] md:text-[160px] text-primary/20 leading-none block mb-4">404</span>
            <h1 class="font-[Fraunces] text-3xl md:text-5xl text-white mb-4">Página no encontrada</h1>
            <p class="text-on-surface-variant text-lg mb-8 max-w-md mx-auto">La página que buscas no existe o ha sido movida.</p>
            <a href="/" class="inline-flex items-center gap-2 bg-primary text-on-primary px-8 py-4 rounded-full text-xs uppercase tracking-widest font-semibold hover:bg-primary-fixed-dim transition-colors">
                Volver al inicio
                <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </a>
        </div>
    </main>
</BaseLayout>
