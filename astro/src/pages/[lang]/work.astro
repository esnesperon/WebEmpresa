---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OptimizedImage from '../../components/OptimizedImage.astro';
import { getCollection } from 'astro:content';
import { useTranslations, getLocalizedPath, type Lang } from '../../i18n/ui';
import { getSeo } from '../../i18n/seo';

export function getStaticPaths() {
    return [
        { params: { lang: 'en' } },
        { params: { lang: 'fr' } },
    ];
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const seo = getSeo(lang, 'work');
const locale = lang === 'en' ? 'en-US' : lang === 'fr' ? 'fr-FR' : 'es-ES';

const projects = await getCollection('projects');
const featured = projects.filter(p => p.data.featured && p.id.startsWith(`${lang}/`));

function getProjectSlug(id, lang) {
    return id.replace(`${lang}/`, '').replace('.md', '');
}
---

<BaseLayout title={seo.title} description={seo.description} locale={locale} serviceArea={seo.serviceArea} tags={seo.keywords}>
    <header class="relative pt-48 md:pt-64 pb-32 px-6 md:px-12 max-w-[1440px] mx-auto w-full cinematic-fade-top">
        <div class="max-w-4xl">
            <h1 class="font-[Fraunces] text-5xl md:text-7xl lg:text-[80px] text-on-background mb-8">{t('work.title')}</h1>
            <p class="text-lg text-on-surface-variant max-w-2xl">{t('work.desc')}</p>
        </div>
    </header>

    <main class="flex-grow px-6 md:px-12 max-w-[1440px] mx-auto w-full pb-32 md:pb-64">
        <div class="grid grid-cols-12 gap-6">
            {featured.map((project, i) => (
                <a href={getLocalizedPath(lang, `/work/${getProjectSlug(project.id, lang)}`)} class:list={[
                    'group relative overflow-hidden rounded-xl liquid-glass cursor-pointer',
                    i === 0 ? 'col-span-12 lg:col-span-8 h-[600px]' : i === 1 ? 'col-span-12 lg:col-span-4 h-[600px]' : 'col-span-12 lg:col-span-6 h-[500px] mt-12'
                ]}>
                    <OptimizedImage src={project.data.image} alt={project.data.title} loading="lazy" class="w-full h-full object-cover grayscale opacity-60 group-hover:grayscale-0 group-hover:scale-105 transition-all duration-1000" sizes="(max-width: 768px) 100vw, 50vw" />
                    <div class="absolute inset-0 bg-gradient-to-t from-background via-background/40 to-transparent z-20"></div>
                    <div class="absolute bottom-0 left-0 p-12 z-30 w-full">
                        <span class="px-3 py-1 bg-primary/10 text-primary text-xs uppercase tracking-wider rounded backdrop-blur-md">{project.data.category}</span>
                        <h2 class="font-[Fraunces] text-3xl text-on-background mt-4 group-hover:text-primary transition-colors">{project.data.title}</h2>
                        <p class="text-base text-on-surface-variant mt-2 opacity-0 group-hover:opacity-100 transform translate-y-4 group-hover:translate-y-0 transition-all duration-500">{project.data.description}</p>
                    </div>
                </a>
            ))}

            <a href="/archive" class="col-span-12 lg:col-span-6 group relative overflow-hidden rounded-xl liquid-glass h-[500px] mt-12 flex items-center justify-center p-12 cursor-pointer">
                <div class="text-center">
                    <span class="material-symbols-outlined text-4xl text-primary mb-6 block">arrow_forward</span>
                    <h2 class="font-[Fraunces] text-3xl text-on-background mb-4">{t('work.archive')}</h2>
                    <p class="text-base text-on-surface-variant">{t('work.archive.desc')}</p>
                </div>
            </a>
        </div>
    </main>
</BaseLayout>
