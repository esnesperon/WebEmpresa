---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations, getLocalizedPath, type Lang } from '../../i18n/ui';
import { getSeo } from '../../i18n/seo';

export function getStaticPaths() {
    return [
        { params: { lang: 'en' } },
        { params: { lang: 'fr' } },
    ];
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const seo = getSeo(lang, 'about');
const locale = lang === 'en' ? 'en-US' : lang === 'fr' ? 'fr-FR' : 'es-ES';

const team = [
    {
        name: 'Alex Esperón Abilleira',
        role: t('about.alexRole'),
        desc: t('about.alexDesc'),
        initials: 'AE',
        gradient: 'from-primary to-secondary',
        textColor: 'text-white',
        shadowColor: 'rgba(196,192,255,0.3)',
        linkedin: 'https://www.linkedin.com/in/%C3%A1lex-esper%C3%B3n-abilleira-b8505933b/',
    },
    {
        name: 'Sergio Robles Martí',
        role: t('about.sergioRole'),
        desc: t('about.sergioDesc'),
        initials: 'SR',
        gradient: 'from-secondary to-tertiary',
        textColor: 'text-white',
        shadowColor: 'rgba(104,219,173,0.3)',
        linkedin: null,
    },
    {
        name: 'Javier',
        role: t('about.javierRole'),
        desc: t('about.javierDesc'),
        initials: 'J',
        gradient: 'from-tertiary to-primary',
        textColor: 'text-[#2a1700]',
        shadowColor: 'rgba(247,187,116,0.3)',
        linkedin: 'https://www.linkedin.com/in/javier-b-a5b97435b/',
    },
];

const pillars = [
    { icon: 'check_circle', title: t('about.pillar1Title'), desc: t('about.pillar1Desc') },
    { icon: 'check_circle', title: t('about.pillar2Title'), desc: t('about.pillar2Desc') },
    { icon: 'check_circle', title: t('about.pillar3Title'), desc: t('about.pillar3Desc') },
    { icon: 'check_circle', title: t('about.pillar4Title'), desc: t('about.pillar4Desc') },
];

const stats = [
    { num: '50+', label: t('about.stat1Label') },
    { num: '6+', label: t('about.stat2Label') },
    { num: 'UE', label: t('about.stat3Label') },
];

const testimonials = [
    { body: t('about.testimonial1Body'), name: t('about.testimonial1Name'), role: t('about.testimonial1Role'), initials: 'M.R.' },
    { body: t('about.testimonial2Body'), name: t('about.testimonial2Name'), role: t('about.testimonial2Role'), initials: 'J.L.' },
    { body: t('about.testimonial3Body'), name: t('about.testimonial3Name'), role: t('about.testimonial3Role'), initials: 'A.G.' },
];

const reviews = testimonials.map(t => ({ author: t.name, body: t.body, rating: 5 }));
---

<BaseLayout
    title={seo.title}
    description={seo.description}
    type="website"
    reviews={reviews}
    locale={locale}
    breadcrumbs={[
        { name: t('about.breadcrumbHome'), url: `https://orviq.net/${lang === 'en' ? 'en' : lang === 'fr' ? 'fr' : ''}` },
        { name: t('about.breadcrumb'), url: `https://orviq.net/${lang === 'en' ? 'en' : lang === 'fr' ? 'fr' : ''}/about` },
    ]}
>
    <main class="flex-grow pt-40 pb-24">
        <!-- Hero -->
        <section class="max-w-[1440px] mx-auto px-6 md:px-16 mb-24">
            <span class="text-xs text-primary uppercase tracking-[0.2em] mb-4 block font-semibold">{t('about.heroLabel')}</span>
            <h1 class="font-[Fraunces] text-5xl md:text-7xl lg:text-[80px] leading-[1.1] tracking-[-0.02em] font-semibold text-on-background mb-8 max-w-4xl">
                {t('about.heroTitle')}<span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">{t('about.heroTitleHighlight')}</span>{t('about.heroTitleEnd')}
            </h1>
            <p class="text-lg text-on-surface-variant max-w-2xl leading-relaxed">{t('about.heroDesc')}</p>
        </section>

        <!-- Stats -->
        <section class="max-w-[1440px] mx-auto px-6 md:px-16 mb-24">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {stats.map(stat => (
                    <div class="liquid-glass rounded-xl p-8 text-center">
                        <span class="font-[Fraunces] text-5xl text-primary mb-2 block">{stat.num}</span>
                        <span class="text-sm text-on-surface-variant uppercase tracking-widest">{stat.label}</span>
                    </div>
                ))}
            </div>
        </section>

        <!-- Filosofía -->
        <section class="max-w-[1440px] mx-auto px-6 md:px-16 mb-24">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div>
                    <h2 class="font-[Fraunces] text-3xl md:text-[48px] leading-[1.2] font-semibold text-on-background mb-6">{t('about.howTitle')}</h2>
                    <div class="space-y-6">
                        {pillars.map(pillar => (
                            <div class="flex gap-4">
                                <span class="material-symbols-outlined text-primary text-2xl flex-shrink-0">{pillar.icon}</span>
                                <div>
                                    <h3 class="text-white font-semibold mb-1">{pillar.title}</h3>
                                    <p class="text-on-surface-variant text-sm">{pillar.desc}</p>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
                <div class="relative h-[500px] rounded-2xl overflow-hidden liquid-glass">
                    <img
                        src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=2070&auto=format&fit=crop"
                        alt={t('about.teamImgAlt')}
                        class="w-full h-full object-cover opacity-60 mix-blend-luminosity"
                        loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-background via-background/40 to-transparent"></div>
                </div>
            </div>
        </section>

        <!-- Equipo / Founders -->
        <section class="max-w-[1440px] mx-auto px-6 md:px-16 mb-24">
            <h2 class="font-[Fraunces] text-3xl md:text-[48px] leading-[1.2] font-semibold text-on-background mb-4 text-center">{t('about.teamTitle')}</h2>
            <p class="text-on-surface-variant text-center max-w-2xl mx-auto mb-12">{t('about.teamSubtitle')}</p>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {team.map(member => (
                    <div class="liquid-glass rounded-xl p-8 text-center" itemscope itemtype="https://schema.org/Person">
                        <meta itemprop="name" content={member.name} />
                        <meta itemprop="jobTitle" content={member.role} />
                        <div itemprop="worksFor" itemscope itemtype="https://schema.org/Organization">
                            <meta itemprop="name" content="Orviq" />
                        </div>
                        <div class={`w-16 h-16 rounded-full bg-gradient-to-br ${member.gradient} flex items-center justify-center ${member.textColor} font-bold text-xl mx-auto mb-4 shadow-[0_0_20px_${member.shadowColor}]`}>{member.initials}</div>
                        <h3 class="text-white font-semibold text-lg" itemprop="name">{member.name}</h3>
                        <p class={`text-sm mb-3 ${member.initials === 'AE' ? 'text-primary' : member.initials === 'SR' ? 'text-secondary' : 'text-tertiary'}`} itemprop="jobTitle">{member.role}</p>
                        <p class="text-on-surface-variant text-sm leading-relaxed">{member.desc}</p>
                        {member.linkedin && (
                            <a href={member.linkedin} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 mt-3 text-on-surface-variant hover:text-primary transition-colors text-sm" aria-label={`LinkedIn ${member.name}`}>
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                                {t('about.linkedin')}
                            </a>
                        )}
                    </div>
                ))}
            </div>
        </section>

        <!-- Testimonios -->
        <section class="max-w-[1440px] mx-auto px-6 md:px-16 mb-24">
            <h2 class="font-[Fraunces] text-3xl md:text-[48px] leading-[1.2] font-semibold text-on-background mb-12 text-center">{t('about.testimonialsTitle')}</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {testimonials.map(testimonial => (
                    <div class="liquid-glass rounded-xl p-8" itemscope itemtype="https://schema.org/Review">
                        <div itemprop="itemReviewed" itemscope itemtype="https://schema.org/Organization">
                            <meta itemprop="name" content="Orviq Studio" />
                        </div>
                        <div class="flex items-center gap-1 mb-4">
                            {[1,2,3,4,5].map(() => (
                                <span class="material-symbols-outlined text-primary text-lg" style="font-variation-settings: 'FILL' 1;">star</span>
                            ))}
                        </div>
                        <p class="text-on-surface-variant mb-6 leading-relaxed" itemprop="reviewBody">{testimonial.body}</p>
                        <div class="flex items-center gap-3" itemprop="author" itemscope itemtype="https://schema.org/Person">
                            <div class="w-10 h-10 rounded-full bg-primary/20 flex items-center justify-center text-primary font-semibold">{testimonial.initials}</div>
                            <div>
                                <p class="text-sm text-white font-medium" itemprop="name">{testimonial.name}</p>
                                <p class="text-xs text-on-surface-variant">{testimonial.role}</p>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <!-- CTA -->
        <section class="max-w-[1440px] mx-auto px-6 md:px-16">
            <div class="liquid-glass-strong rounded-xl p-8 md:p-16 text-center relative overflow-hidden">
                <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-primary/10 via-transparent to-transparent opacity-50"></div>
                <div class="relative z-10 max-w-2xl mx-auto">
                    <h2 class="font-[Fraunces] text-3xl md:text-[48px] bg-clip-text text-transparent bg-gradient-to-br from-white to-white/70 mb-6">{t('about.ctaTitle')}</h2>
                    <p class="text-lg text-on-surface-variant mb-8">{t('about.ctaDesc')}</p>
                    <a href={getLocalizedPath(lang, '/contact')} class="inline-flex items-center gap-2 bg-primary text-on-primary px-8 py-4 rounded-full text-xs uppercase tracking-widest font-semibold hover:bg-primary-fixed-dim transition-colors shadow-[0_0_20px_rgba(196,192,255,0.2)]">
                        {t('about.ctaBtn')} <span class="material-symbols-outlined text-sm">arrow_forward</span>
                    </a>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>