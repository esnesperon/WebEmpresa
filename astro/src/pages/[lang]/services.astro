---
import BaseLayout from '../../layouts/BaseLayout.astro';
import services from '../../data/services.json';
import { useTranslations, getLocalizedPath, type Lang } from '../../i18n/ui';
import { getSeo } from '../../i18n/seo';
import { getServiceDetail } from '../../i18n/service-details';

export function getStaticPaths() {
    return [
        { params: { lang: 'en' } },
        { params: { lang: 'fr' } },
    ];
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const seo = getSeo(lang, 'services');
const locale = lang === 'en' ? 'en-US' : lang === 'fr' ? 'fr-FR' : 'es-ES';

// Build service details for client-side use
const serviceDetailsForClient: Record<string, { what: string; includes: string[]; for: string }> = {};
for (const service of services) {
    const detail = getServiceDetail(service.id, lang);
    if (detail) serviceDetailsForClient[service.id] = detail;
}
---

<BaseLayout
    title={seo.title}
    description={seo.description}
    locale={locale}
    type="service"
    serviceArea={seo.serviceArea}
    tags={seo.keywords}
>
    <main class="relative pb-32">
        <section class="relative pt-48 md:pt-64 pb-32 px-6 max-w-[1440px] mx-auto flex flex-col items-center text-center">
            <span class="text-xs text-primary uppercase tracking-[0.2em] mb-6 liquid-glass-strong px-4 py-2 rounded-full inline-flex items-center gap-2">
                <span class="material-symbols-outlined text-[16px]">model_training</span>
                {t('services.what')}
            </span>
            <h1 class="font-[Fraunces] text-5xl md:text-7xl lg:text-[80px] text-white mb-8 max-w-4xl">
                {t('services.title').split(' ').slice(0, -1).join(' ')} <br /> <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-secondary">{t('services.title').split(' ').slice(-1)}</span>
            </h1>
            <p class="text-lg text-on-surface-variant max-w-2xl">
                {t('services.subtitle')}
            </p>
        </section>

        <section class="max-w-[1440px] mx-auto px-6 grid grid-cols-1 md:grid-cols-12 gap-6 relative z-10">
            {services.map((service, i) => (
                <div class:list={[`${service.span} liquid-glass rounded-xl p-10 flex flex-col justify-end ${service.height} relative overflow-hidden group cursor-pointer service-card`, i === 0 && 'md:col-span-8']} data-service={service.id} itemscope itemtype="https://schema.org/ProfessionalService">
                    <meta itemprop="name" content={String((service as any)[lang]?.title ?? service.es.title).replaceAll('\n', ' ')} />
                    <meta itemprop="description" content={String((service as any)[lang]?.description ?? service.es.description)} />
                    <meta itemprop="provider" content="Orviq" />
                    <div itemprop="areaServed" itemscope itemtype="https://schema.org/Place">
                        <meta itemprop="name" content={lang === 'fr' ? 'Union européenne' : 'European Union'} />
                    </div>
                    {i === 0 && <div class="absolute inset-0 bg-gradient-to-br from-primary-container/20 to-transparent z-0"></div>}
                    <div class:list={['relative z-10 w-full', i === 0 ? 'max-w-lg' : 'flex-grow flex flex-col justify-between']}>
                        {i === 0 ? (
                            <>
                                <div class="w-12 h-12 rounded-full liquid-glass-strong flex items-center justify-center mb-6 text-primary">
                                    <span class="material-symbols-outlined">{service.icon}</span>
                                </div>
                                <h2 class="font-[Fraunces] text-5xl text-white mb-4 whitespace-pre-line">{(service as any)[lang]?.title ?? service.es.title}</h2>
                                <p class="text-base text-on-surface-variant mb-8">{(service as any)[lang]?.description ?? service.es.description}</p>
                                <button class="explore-btn inline-flex items-center gap-2 text-xs text-primary hover:text-white transition-colors uppercase tracking-widest" data-service={service.id}>
                                    {t('services.card.cta')} <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
                                </button>
                            </>
                        ) : (
                            <>
                                <div class="w-12 h-12 rounded-full liquid-glass-strong flex items-center justify-center text-primary">
                                    <span class="material-symbols-outlined">{service.icon}</span>
                                </div>
                                <div>
                                    <h2 class="font-[Fraunces] text-3xl text-white mb-4 whitespace-pre-line">{(service as any)[lang]?.title ?? service.es.title}</h2>
                                    <p class="text-base text-on-surface-variant mb-4">{(service as any)[lang]?.description ?? service.es.description}</p>
                                    <button class="explore-btn inline-flex items-center gap-2 text-xs text-primary hover:text-white transition-colors uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity" data-service={service.id}>
                                        {t('services.card.cta')} <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
                                    </button>
                                </div>
                            </>
                        )}
                    </div>
                </div>
            ))}
        </section>

        <div class="mt-16 text-center px-6">
            <a href={getLocalizedPath(lang, '/contact')} class="bg-primary text-on-primary px-8 py-4 rounded-full text-xs uppercase tracking-widest font-semibold hover:bg-primary-fixed-dim transition-colors inline-block">
                {t('services.cta')}
            </a>
        </div>
    </main>

    <!-- Detail Modal -->
    <div id="service-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-6 bg-background/80 backdrop-blur-[20px]">
        <div class="bg-surface-container-high/90 backdrop-blur-[40px] border border-outline-variant/20 rounded-2xl p-10 max-w-2xl w-full max-h-[90vh] overflow-y-auto shadow-[0_0_60px_rgba(196,192,255,0.1)]">
            <div class="flex justify-between items-start mb-6">
                <div id="modal-icon" class="w-12 h-12 rounded-full liquid-glass-strong flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined" id="modal-icon-name">model_training</span>
                </div>
                <button id="modal-close" class="text-on-surface-variant hover:text-on-surface transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            <h2 id="modal-title" class="font-[Fraunces] text-[40px] leading-tight text-on-surface mb-4"></h2>
            <p id="modal-what" class="text-base leading-[1.7] text-on-surface-variant mb-8"></p>

            <div class="mb-8">
                <p class="text-xs text-primary uppercase tracking-widest font-semibold mb-4">{t('services.detail.what')}</p>
                <ul id="modal-includes" class="space-y-3"></ul>
            </div>

            <div class="bg-primary/5 border border-primary/15 rounded-xl p-6 mb-8">
                <p class="text-xs text-primary uppercase tracking-widest font-semibold mb-2">{t('services.detail.for')}</p>
                <p id="modal-for" class="text-base leading-[1.6] text-on-surface-variant"></p>
            </div>

            <a id="modal-cta" href={getLocalizedPath(lang, '/contact')} class="w-full bg-primary text-on-primary px-6 py-4 rounded-full text-xs uppercase tracking-widest font-semibold hover:bg-primary-fixed-dim transition-colors block text-center">
                {t('services.detail.cta')}
            </a>
        </div>
    </div>

    <script is:inline define:vars={{ serviceDetailsForClient }}>
        const modal = document.getElementById('service-modal');
        const modalClose = document.getElementById('modal-close');

        document.querySelectorAll('.explore-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const id = btn.dataset.service;
                openModal(id);
            });
        });

        document.querySelectorAll('.service-card').forEach(card => {
            card.addEventListener('click', () => {
                openModal(card.dataset.service);
            });
        });

        function openModal(id) {
            const detail = serviceDetailsForClient[id];
            if (!detail) return;

            const card = document.querySelector(`.service-card[data-service="${id}"]`);
            const title = card?.querySelector('h2')?.textContent || '';
            const icon = card?.querySelector('.material-symbols-outlined')?.textContent || 'model_training';

            document.getElementById('modal-title').textContent = title;
            document.getElementById('modal-icon-name').textContent = icon;
            document.getElementById('modal-what').textContent = detail.what;
            document.getElementById('modal-for').textContent = detail.for;

            const includesList = document.getElementById('modal-includes');
            includesList.innerHTML = '';
            detail.includes.forEach(item => {
                const li = document.createElement('li');
                li.className = 'flex items-start gap-3 text-sm text-on-surface-variant';
                const icon = document.createElement('span');
                icon.className = 'material-symbols-outlined text-primary text-[16px] mt-0.5 flex-shrink-0';
                icon.textContent = 'check_circle';
                const span = document.createElement('span');
                span.textContent = item;
                li.appendChild(icon);
                li.appendChild(span);
                includesList.appendChild(li);
            });

            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.style.overflow = 'hidden';
        }

        modalClose.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => {
            if (e.target === modal) closeModal();
        });
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeModal();
        });

        function closeModal() {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.body.style.overflow = '';
        }
    </script>
</BaseLayout>
