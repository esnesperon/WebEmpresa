    line-height: 1.75;
    font-size: 1rem;
}
.legal-content p {
    margin-bottom: 1.25rem;
    color: #b4b4c8;
}
.legal-content h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.6rem;
    font-weight: 600;
    color: #ffffff;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
}
.legal-content h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: #e0e0f0;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
}
.legal-content ul, .legal-content ol {
    margin-left: 1.5rem;
    margin-bottom: 1.25rem;
}
.legal-content ul { list-style-type: disc; }
.legal-content ol { list-style-type: decimal; }
.legal-content li {
    margin-bottom: 0.5rem;
    color: #b4b4c8;
    padding-left: 0.25rem;
}
.legal-content strong {
    color: #e8e8f4;
    font-weight: 600;
}
.legal-content a {
    color: #c4c0ff;
    text-decoration: underline;
    text-underline-offset: 3px;
}
.legal-content a:hover { color: #ffffff; }
table { width: 100%; border-collapse: collapse; margin-bottom: 1.5rem; font-size: 0.875rem; }
thead tr { border-bottom: 1px solid rgba(255,255,255,0.12); }
thead th { padding: 0.75rem 1rem 0.75rem 0; font-weight: 600; color: #e8e8f4; text-align: left; }
