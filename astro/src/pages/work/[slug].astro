---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import { useTranslations } from '../../i18n/ui';

export async function getStaticPaths() {
    const projects = await getCollection('projects');
    return projects
        .filter(p => p.id.startsWith('es/'))
        .map(project => ({
            params: { slug: project.id.replace('es/', '').replace('.md', '') },
            props: { project },
        }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const t = useTranslations('es');
---

<BaseLayout
    title={`${project.data.title} | Orviq`}
    description={project.data.description}
    image={project.data.image}
    type="website"
    locale="es-ES"
>
    <div class="pt-40 pb-24 px-6 md:px-16 max-w-[1440px] mx-auto">
        <!-- Breadcrumb -->
        <nav class="mb-8">
            <a href="/work" class="text-primary text-xs uppercase tracking-widest hover:text-white transition-colors">{t('work.back')}</a>
        </nav>

        <!-- Hero Image -->
        <div class="relative h-[500px] md:h-[700px] rounded-2xl overflow-hidden mb-16">
            <img src={project.data.image} alt={project.data.title} loading="eager" decoding="async" width="1600" height="900" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-background via-background/20 to-transparent"></div>
            <div class="absolute bottom-0 left-0 p-12">
                <span class="px-3 py-1 bg-primary/10 text-primary text-xs uppercase tracking-wider rounded backdrop-blur-md">{project.data.category}</span>
                <h1 class="font-[Fraunces] text-5xl md:text-7xl text-white mt-4">{project.data.title}</h1>
            </div>
        </div>

        <!-- Content -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
            <!-- Main Content -->
            <div class="lg:col-span-8">
                <article class="prose prose-invert prose-lg max-w-none">
                    <Content />
                </article>
            </div>

            <!-- Sidebar -->
            <aside class="lg:col-span-4 space-y-8">
                <div class="liquid-glass rounded-xl p-8">
                    <h3 class="text-xs uppercase tracking-widest text-on-surface-variant mb-4">{t('work.projectDetails')}</h3>
                    <div class="space-y-4">
                        <div>
                            <span class="text-xs text-on-surface-variant uppercase">{t('work.categoryLabel')}</span>
                            <p class="text-white">{project.data.category}</p>
                        </div>
                        <div>
                            <span class="text-xs text-on-surface-variant uppercase">{t('work.dateLabel')}</span>
                            <p class="text-white">{project.data.date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long' })}</p>
                        </div>
                        {project.data.tags && (
                            <div>
                                <span class="text-xs text-on-surface-variant uppercase">{t('work.tagsLabel')}</span>
                                <div class="flex flex-wrap gap-2 mt-2">
                                    {project.data.tags.map(tag => (
                                        <span class="px-2 py-1 bg-primary/10 text-primary text-xs rounded">{tag}</span>
                                    ))}
                                </div>
                            </div>
                        )}
                    </div>
                </div>

                {project.data.link && (
                    <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="block liquid-glass-strong text-center text-white px-8 py-4 rounded-xl text-xs uppercase tracking-widest hover:bg-primary/20 transition-colors">
                        Ver proyecto <span class="material-symbols-outlined text-sm align-middle">open_in_new</span>
                    </a>
                )}

                <a href="/contact" class="block liquid-glass-strong text-center text-white px-8 py-4 rounded-xl text-xs uppercase tracking-widest hover:bg-primary/20 transition-colors">
                    {t('work.startSimilar')}
                </a>
            </aside>
        </div>
    </div>
</BaseLayout>