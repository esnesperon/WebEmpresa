---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/ui';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<div id="cookie-banner" class="fixed bottom-6 left-6 right-6 md:left-auto md:right-6 md:w-[420px] z-[100] bg-surface-container-high/90 backdrop-blur-[40px] border border-outline-variant/20 rounded-2xl p-6 shadow-[0_0_40px_rgba(0,0,0,0.4)] hidden" role="dialog" aria-label={t('cookie.panel.title')}>
    <div class="flex items-start justify-between mb-4">
        <h3 class="font-[Fraunces] text-xl text-on-background">{t('footer.cookies')}</h3>
        <button id="cookie-close" class="text-on-surface-variant hover:text-on-background transition-colors" aria-label={t('cookie.close')}>
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>
    <p class="text-sm text-on-surface-variant mb-6 leading-relaxed">
        {t('cookie.desc')} <a href={getLocalizedPath(lang, '/cookies')} class="text-primary hover:text-white transition-colors underline">{t('cookie.link')}</a>.
    </p>
    <div class="flex flex-col gap-3">
        <button id="cookie-accept-all" class="bg-surface-container-highest text-on-surface border border-outline-variant px-6 py-3 rounded-full text-xs uppercase tracking-widest font-semibold hover:bg-surface-bright transition-colors">
            {t('cookie.accept')}
        </button>
        <button id="cookie-reject" class="bg-surface-container-highest text-on-surface border border-outline-variant px-6 py-3 rounded-full text-xs uppercase tracking-widest font-semibold hover:bg-surface-bright transition-colors">
            {t('cookie.reject')}
        </button>
        <button id="cookie-customize-btn" class="text-on-surface-variant hover:text-on-background text-xs uppercase tracking-widest font-semibold transition-colors py-2">
            {t('cookie.customize')}
        </button>
    </div>
</div>

<div id="cookie-panel" class="fixed inset-0 z-[100] bg-background/80 backdrop-blur-[20px] hidden flex items-center justify-center p-6" role="dialog" aria-label={t('cookie.panel.title')} aria-modal="true">
    <div class="bg-surface-container-high border border-outline-variant/20 rounded-2xl p-8 max-w-lg w-full shadow-[0_0_60px_rgba(0,0,0,0.5)]">
        <div class="flex items-start justify-between mb-6">
            <h3 class="font-[Fraunces] text-2xl text-on-background">{t('cookie.panel.title')}</h3>
            <button id="cookie-panel-close" class="text-on-surface-variant hover:text-on-background transition-colors" aria-label={t('cookie.close')}>
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>

        <div class="space-y-4 mb-8">
            <div class="flex items-center justify-between p-4 bg-surface-container/50 rounded-xl">
                <div>
                    <p class="text-sm font-semibold text-on-background">{t('cookie.necessary')}</p>
                    <p class="text-xs text-on-surface-variant mt-1">{t('cookie.necessary.desc')}</p>
                </div>
                <div class="w-12 h-6 bg-primary border border-outline-variant/30 rounded-full relative flex items-center px-1 cursor-default">
                    <div class="w-4 h-4 bg-white rounded-full ml-auto shadow-sm"></div>
                </div>
            </div>

            <div class="flex items-center justify-between p-4 bg-surface-container/50 rounded-xl">
                <div>
                    <p class="text-sm font-semibold text-on-background">{t('cookie.preferences')}</p>
                    <p class="text-xs text-on-surface-variant mt-1">{t('cookie.preferences.desc')}</p>
                </div>
                <button id="toggle-preferences" class="cookie-toggle w-12 h-6 bg-surface-container-highest border border-outline-variant/30 rounded-full relative flex items-center px-1" data-category="preferences">
                    <div class="toggle-dot w-4 h-4 bg-white rounded-full transition-transform shadow-sm"></div>
                </button>
            </div>

            <div class="flex items-center justify-between p-4 bg-surface-container/50 rounded-xl">
                <div>
                    <p class="text-sm font-semibold text-on-background">{t('cookie.analytics')}</p>
                    <p class="text-xs text-on-surface-variant mt-1">{t('cookie.analytics.desc')}</p>
                </div>
                <button id="toggle-analytics" class="cookie-toggle w-12 h-6 bg-surface-container-highest border border-outline-variant/30 rounded-full relative flex items-center px-1" data-category="analytics">
                    <div class="toggle-dot w-4 h-4 bg-white rounded-full transition-transform shadow-sm"></div>
                </button>
            </div>

            <div class="flex items-center justify-between p-4 bg-surface-container/50 rounded-xl">
                <div>
                    <p class="text-sm font-semibold text-on-background">{t('cookie.marketing')}</p>
                    <p class="text-xs text-on-surface-variant mt-1">{t('cookie.marketing.desc')}</p>
                </div>
                <button id="toggle-marketing" class="cookie-toggle w-12 h-6 bg-surface-container-highest border border-outline-variant/30 rounded-full relative flex items-center px-1" data-category="marketing">
                    <div class="toggle-dot w-4 h-4 bg-white rounded-full transition-transform shadow-sm"></div>
                </button>
            </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
            <button id="cookie-save" class="flex-1 bg-primary text-on-primary px-6 py-3 rounded-full text-xs uppercase tracking-widest font-semibold hover:bg-primary-fixed-dim transition-colors">
                {t('cookie.save')}
            </button>
            <button id="cookie-accept-all-panel" class="flex-1 bg-transparent border border-outline-variant text-on-surface px-6 py-3 rounded-full text-xs uppercase tracking-widest font-semibold hover:bg-surface-container-highest transition-colors">
                {t('cookie.acceptAll')}
            </button>
        </div>
    </div>
</div>

<script is:inline>
    (function() {
        const COOKIE_NAME = 'orviq_cookie_consent';
        const COOKIE_MAX_AGE = 31536000; // 1 year in seconds
        const banner = document.getElementById('cookie-banner');
        const panel = document.getElementById('cookie-panel');

        function getCookie(name) {
            const match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
            if (match) {
                try {
                    return JSON.parse(decodeURIComponent(match[2]));
                } catch (e) {
                    return null;
                }
            }
            return null;
        }

        function setCookie(name, value, maxAge) {
            const encoded = encodeURIComponent(JSON.stringify(value));
            document.cookie = name + '=' + encoded + ';path=/;max-age=' + maxAge + ';SameSite=Lax';
        }

        function showBanner() {
            if (banner) banner.classList.remove('hidden');
        }

        function hideBanner() {
            if (banner) banner.classList.add('hidden');
        }

        function showPanel() {
            if (panel) panel.classList.remove('hidden');
        }

        function hidePanel() {
            if (panel) panel.classList.add('hidden');
        }

        function updateToggles(consent) {
            document.querySelectorAll('.cookie-toggle').forEach(toggle => {
                const category = toggle.dataset.category;
                const dot = toggle.querySelector('.toggle-dot');
                const isActive = consent[category] === true;

                if (isActive) {
                    toggle.classList.remove('bg-surface-container-highest');
                    toggle.classList.add('bg-primary');
                    dot.classList.add('translate-x-6');
                } else {
                    toggle.classList.add('bg-surface-container-highest');
                    toggle.classList.remove('bg-primary');
                    dot.classList.remove('translate-x-6');
                }
            });
        }

        function toggleCategory(category) {
            const consent = getCookie(COOKIE_NAME) || {};
            consent[category] = !consent[category];
            setCookie(COOKIE_NAME, consent, COOKIE_MAX_AGE);
            updateToggles(consent);
        }

        // Check existing consent
        const existing = getCookie(COOKIE_NAME);
        if (!existing) {
            showBanner();
        }

        // Banner buttons
        document.getElementById('cookie-accept-all')?.addEventListener('click', () => {
            setCookie(COOKIE_NAME, { necessary: true, preferences: true, analytics: true, marketing: true, timestamp: new Date().toISOString() }, COOKIE_MAX_AGE);
            hideBanner();
        });

        document.getElementById('cookie-reject')?.addEventListener('click', () => {
            setCookie(COOKIE_NAME, { necessary: true, preferences: false, analytics: false, marketing: false, timestamp: new Date().toISOString() }, COOKIE_MAX_AGE);
            hideBanner();
        });

        document.getElementById('cookie-customize-btn')?.addEventListener('click', () => {
            hideBanner();
            showPanel();
            updateToggles(getCookie(COOKIE_NAME) || {});
        });

        document.getElementById('cookie-close')?.addEventListener('click', () => {
            hideBanner();
        });

        // Panel buttons
        document.getElementById('cookie-panel-close')?.addEventListener('click', () => {
            hidePanel();
            if (!getCookie(COOKIE_NAME)) showBanner();
        });

        document.getElementById('cookie-save')?.addEventListener('click', () => {
            const consent = getCookie(COOKIE_NAME) || {};
            setCookie(COOKIE_NAME, { ...consent, timestamp: new Date().toISOString() }, COOKIE_MAX_AGE);
            hidePanel();
        });

        document.getElementById('cookie-accept-all-panel')?.addEventListener('click', () => {
            setCookie(COOKIE_NAME, { necessary: true, preferences: true, analytics: true, marketing: true, timestamp: new Date().toISOString() }, COOKIE_MAX_AGE);
            updateToggles(getCookie(COOKIE_NAME));
            hidePanel();
        });

        // Toggle clicks
        document.querySelectorAll('.cookie-toggle').forEach(toggle => {
            toggle.addEventListener('click', () => {
                const category = toggle.dataset.category;
                toggleCategory(category);
            });
        });
    })();
</script>
