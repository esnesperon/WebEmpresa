---
import { getLangFromUrl, useTranslations, languages, getLocalizedPath, type Lang } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Build localized href for each nav link
function localHref(path: string) {
  return getLocalizedPath(lang, path);
}

const navLinks = [
  { href: localHref('/'), label: t('nav.home') },
  { href: localHref('/about'), label: t('nav.about') },
  { href: localHref('/work'), label: t('nav.work') },
  { href: localHref('/services'), label: t('nav.services') },
  { href: localHref('/process'), label: t('nav.process') },
  { href: localHref('/faq'), label: t('nav.faq') },
  { href: localHref('/blog'), label: t('nav.blog') },
  { href: localHref('/contact'), label: t('nav.contact') },
];

const currentPath = Astro.url.pathname;

// Language switcher: same page in other languages
function getLangSwitchUrl(targetLang: Lang): string {
  let pathWithoutLang = currentPath;
  // Remove existing lang prefix if any
  for (const l of Object.keys(languages)) {
    if (l !== 'es' && pathWithoutLang.startsWith(`/${l}`)) {
      pathWithoutLang = pathWithoutLang.slice(`/${l}`.length) || '/';
      break;
    }
  }
  return getLocalizedPath(targetLang, pathWithoutLang || '/');
}
---

<nav class="fixed top-0 left-0 right-0 z-50 hidden lg:flex justify-center px-3 sm:px-4 py-2">
    <div class="bg-zinc-950/40 backdrop-blur-[40px] rounded-full border border-white/15 mt-4 shadow-[0_0_40px_rgba(67,62,137,0.15)] flex items-center justify-between w-full max-w-5xl lg:max-w-6xl xl:max-w-7xl 2xl:max-w-[90rem] px-6 sm:px-8 lg:px-10 py-4">
        <a href={localHref('/')} class="flex items-center gap-2 sm:gap-3 flex-shrink-0">
            <svg width="28" height="28" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="50" cy="50" r="48" fill="#131318" stroke="#2a292f" stroke-width="2" />
                <rect x="18" y="18" width="28" height="28" rx="8" fill="#c4c0ff" />
                <rect x="54" y="18" width="28" height="28" rx="8" fill="#433e89" />
                <rect x="18" y="54" width="28" height="28" rx="8" fill="#433e89" />
                <rect x="54" y="54" width="28" height="28" rx="8" fill="#c4c0ff" />
            </svg>
            <span class="text-xl sm:text-2xl font-black tracking-tight text-white uppercase italic leading-none" style="font-family: 'Fraunces', serif;">Orviq</span>
        </a>
        <ul class="flex items-center gap-3 sm:gap-4 lg:gap-6">
            {navLinks.map(link => {
                const isActive = currentPath === link.href || (link.href !== '/' && link.href !== '/en/' && link.href !== '/fr/' && currentPath.startsWith(link.href));
                return (
                    <li>
                        <a
                            href={link.href}
                            class={isActive
                                ? 'text-white font-bold border-b border-indigo-500 pb-0.5 text-xs sm:text-sm lg:text-base tracking-wide uppercase whitespace-nowrap px-1.5 sm:px-2 py-1'
                                : 'text-zinc-400 hover:text-white transition-colors duration-500 text-xs sm:text-sm lg:text-base tracking-wide uppercase whitespace-nowrap px-1.5 sm:px-2 py-1'
                            }
                        >
                            {link.label}
                        </a>
                    </li>
                );
            })}
            <!-- Language switcher -->
            <li class="relative group">
                <button class="flex items-center gap-1 text-zinc-400 hover:text-white transition-colors text-xs sm:text-sm lg:text-base tracking-wide uppercase px-1.5 sm:px-2 py-1" id="lang-btn" aria-label="Language selector" aria-expanded="false" aria-haspopup="true" aria-controls="lang-menu">
                    <span class="material-symbols-outlined text-sm sm:text-base">language</span>
                    {lang.toUpperCase()}
                    <span class="material-symbols-outlined text-sm sm:text-base">expand_more</span>
                </button>
                <div id="lang-menu" class="hidden absolute right-0 top-full mt-2 bg-zinc-900/95 backdrop-blur-[20px] border border-white/10 rounded-xl overflow-hidden min-w-[140px] shadow-[0_8px_32px_rgba(0,0,0,0.4)]">
                    {Object.entries(languages).map(([code, label]) => (
                        <a
                            href={getLangSwitchUrl(code as Lang)}
                            class:list={['flex items-center gap-2 px-4 py-3 text-sm tracking-widest uppercase transition-colors',
                                code === lang ? 'text-primary bg-primary/10' : 'text-zinc-400 hover:text-white hover:bg-white/5'
                            ]}
                        >
                            {code.toUpperCase()} <span class="text-zinc-500 normal-case tracking-normal">{label}</span>
                        </a>
                    ))}
                </div>
            </li>
        </ul>
        <a href={localHref('/contact')} class="bg-primary text-on-primary px-4 sm:px-5 py-2 rounded-full text-xs sm:text-sm lg:text-base tracking-wide uppercase hover:bg-white/90 transition-colors flex-shrink-0">{t('nav.cta')}</a>
    </div>
</nav>

<!-- Mobile Navbar (lg:hidden) -->
<nav class="fixed top-0 left-0 right-0 z-50 lg:hidden p-6 bg-background/80 backdrop-blur-[20px] border-b border-white/5">
    <div class="flex justify-between items-center">
        <a href={localHref('/')} class="flex items-center gap-3">
            <svg width="32" height="32" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="50" cy="50" r="48" fill="#131318" stroke="#2a292f" stroke-width="2" />
                <rect x="18" y="18" width="28" height="28" rx="8" fill="#c4c0ff" />
                <rect x="54" y="18" width="28" height="28" rx="8" fill="#433e89" />
                <rect x="18" y="54" width="28" height="28" rx="8" fill="#433e89" />
                <rect x="54" y="54" width="28" height="28" rx="8" fill="#c4c0ff" />
            </svg>
            <span class="text-2xl font-black tracking-tighter text-white uppercase italic" style="font-family: 'Fraunces', serif;">Orviq</span>
        </a>
        <button id="mobile-menu-btn" class="text-on-background" aria-label="Open mobile menu" aria-expanded="false" aria-controls="mobile-menu">
            <span class="material-symbols-outlined">menu</span>
        </button>
    </div>
    <div id="mobile-menu" class="hidden mt-6 pb-4">
        <ul class="flex flex-col gap-4">
            {navLinks.map(link => (
                <li>
                    <a href={link.href} class="text-zinc-400 hover:text-white transition-colors text-sm uppercase tracking-widest">{link.label}</a>
                </li>
            ))}
        </ul>
        <div class="mt-4 flex gap-2 border-t border-white/10 pt-4">
            {Object.entries(languages).map(([code, label]) => (
                <a href={getLangSwitchUrl(code as Lang)} class:list={['px-3 py-1 rounded-full text-xs uppercase tracking-widest transition-colors', code === lang ? 'bg-primary text-on-primary' : 'text-zinc-400 hover:text-white']}>
                    {code}
                </a>
            ))}
        </div>
    </div>
</nav>

<script>
    // Mobile menu toggle
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (btn && menu) {
        btn.addEventListener('click', () => {
            menu.classList.toggle('hidden');
            const isExpanded = btn.getAttribute('aria-expanded') === 'true';
            btn.setAttribute('aria-expanded', String(!isExpanded));
        });
    }

    // Language dropdown toggle
    const langBtn = document.getElementById('lang-btn');
    const langMenu = document.getElementById('lang-menu');
    if (langBtn && langMenu) {
        langBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            langMenu.classList.toggle('hidden');
            const isExpanded = langBtn.getAttribute('aria-expanded') === 'true';
            langBtn.setAttribute('aria-expanded', String(!isExpanded));
        });
        document.addEventListener('click', () => {
            langMenu.classList.add('hidden');
            langBtn.setAttribute('aria-expanded', 'false');
        });
    }

    // Auto-detect language on first visit
    const hasLangPref = localStorage.getItem('orviq-lang');
    if (!hasLangPref) {
        const browserLang = navigator.language.slice(0, 2).toLowerCase();
        const supported = ['en', 'fr'];
        if (supported.includes(browserLang)) {
            const current = window.location.pathname;
            const alreadyPrefixed = supported.some(l => current.startsWith(`/${l}`));
            if (!alreadyPrefixed) {
                localStorage.setItem('orviq-lang', browserLang);
                window.location.replace(`/${browserLang}${current === '/' ? '' : current}`);
            }
        } else {
            localStorage.setItem('orviq-lang', 'es');
        }
    }

    // Store lang preference on manual switch
    document.querySelectorAll('#lang-menu a').forEach(a => {
        a.addEventListener('click', (e) => {
            const href = (e.currentTarget as HTMLAnchorElement).href;
            const lang = new URL(href).pathname.split('/')[1];
            const supported = ['en', 'fr'];
            localStorage.setItem('orviq-lang', supported.includes(lang) ? lang : 'es');
        });
    });
</script>
